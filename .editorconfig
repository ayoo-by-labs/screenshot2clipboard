root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{swift,h,m,mm}]
indent_style = tab

# Vendored code stays as upstream ships it.
[Screenshot2Clipboard/Utilities/**]
indent_style = space
indent_size = 4

[*.{yml,yaml,json,md}]
indent_style = space
indent_size = 2
